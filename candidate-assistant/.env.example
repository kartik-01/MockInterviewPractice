# Server (Fastify) — copy to `candidate-assistant/.env` (see README)
DEEPGRAM_API_KEY=
GROQ_API_KEY=
# Default: OpenAI GPT-OSS 120B on Groq (override if needed)
GROQ_MODEL=openai/gpt-oss-120b
# Nova 3 general (streaming; override if your project uses another id)
DEEPGRAM_MODEL=nova-3-general
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Client (Vite) — optional; default matches local server
# VITE_WS_URL=ws://localhost:3001/ws/listen
